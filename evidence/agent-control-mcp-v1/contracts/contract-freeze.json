{
  "schema_revision": "starclock.agent-control-contract-freeze.v1",
  "result": "pass",
  "policy_sha256": "43bd23d0a29beecef4bdb8d89db77b55e02a69ba1310babce3211b494e7dbd7e",
  "library": {
    "crate": "starclock-agent-api",
    "schema_revision": "agent-api-v1",
    "schema_bundle_sha256": "1746004f3f73ebbe6fb4cce4b850dd6813a1dc3a8584c3d191903328c0206725",
    "responsibility_modules": [
      "action",
      "error",
      "observation",
      "schema",
      "session"
    ],
    "allowed_additive_responsibility_modules": [
      "activity_action",
      "activity_observation",
      "activity_session"
    ],
    "session_operations": [
      "list_scenarios",
      "create",
      "observe",
      "apply_action",
      "export_replay",
      "verify_replay",
      "close"
    ],
    "requires_async_runtime": false,
    "requires_transport": false
  },
  "mcp": {
    "revision": "2025-11-25",
    "server_name": "starclock-mcp",
    "tools": [
      "starclock_close_battle",
      "starclock_create_battle",
      "starclock_export_replay",
      "starclock_list_scenarios",
      "starclock_observe_battle",
      "starclock_play_action",
      "starclock_verify_replay"
    ],
    "allowed_additive_tools": [
      "starclock_close_activity",
      "starclock_create_universe",
      "starclock_export_activity_replay",
      "starclock_observe_activity",
      "starclock_play_activity_action",
      "starclock_verify_activity_replay"
    ],
    "resources": [
      "starclock://catalog/manifest",
      "starclock://rules/core-combat"
    ],
    "allowed_additive_resources": [
      "starclock://rules/standard-universe",
      "starclock://universe/manifest"
    ],
    "resource_templates": [
      "starclock://character/{form_id}",
      "starclock://scenario/{scenario_id}"
    ],
    "prompts": [
      "starclock_battle_loop"
    ],
    "transports": [
      "stdio",
      "streamable-http"
    ],
    "structured_content_authoritative": true,
    "non_loopback_startup": false
  },
  "cli": {
    "commands": [
      "starclock mcp serve --transport stdio",
      "starclock mcp serve --transport streamable-http --development-loopback --bind IP:PORT --allow-origin ORIGIN"
    ],
    "mcp_failure_exit_code": 8,
    "stdio_stdout": "protocol-only",
    "http_profile": "explicit_loopback_development"
  },
  "examples": [
    {
      "kind": "in-process",
      "path": "crates/starclock-agent-api/examples/g02_in_process.rs",
      "command": "cargo run -p starclock-agent-api --example g02_in_process"
    },
    {
      "kind": "stdio",
      "path": "examples/agent-control/stdio-discovery.mjs",
      "command": "node examples/agent-control/stdio-discovery.mjs PATH_TO_STARCLOCK_BINARY"
    },
    {
      "kind": "authorized-http",
      "path": "crates/starclock-mcp/examples/g02_authorized_http.rs",
      "command": "cargo run -p starclock-mcp --example g02_authorized_http"
    }
  ],
  "guidance": {
    "document": "docs/starclock-agent-integration-contract.md",
    "use_mcp_for": [
      "interoperable tool hosts",
      "human-scale external agent decisions",
      "stdio or reviewed HTTP integration"
    ],
    "do_not_use_mcp_for": [
      "one call per hit/event/trigger",
      "bulk replay verification",
      "high-throughput training",
      "model inference or chain-of-thought storage",
      "arbitrary catalog/spec upload",
      "unreviewed Internet exposure"
    ]
  },
